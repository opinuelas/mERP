@model mERP.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "_LayoutLogin";
}

<div style="width: 480px;">
    <div class="card shadow">
        <div class="card-header bg-dark text-white text-center py-4">
            <h3 class="mb-0">mERP Login</h3>
        </div>
        <div class="card-body p-5">
            <form asp-action="Login" method="post">
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="mb-4">
                    <label asp-for="UserId" class="form-label fw-semibold fs-5"></label>
                    <input asp-for="UserId" class="form-control form-control-lg" autofocus autocomplete="username" />
                    <span asp-validation-for="UserId" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label fw-semibold fs-5"></label>
                    <input asp-for="Password" class="form-control form-control-lg" autocomplete="current-password" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4 form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label">Remember me</label>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-dark btn-lg">Sign In</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
