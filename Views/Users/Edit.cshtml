@model mERP.Data.User

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>User</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <label asp-for="Usrid" class="control-label"></label>
                <input asp-for="Usrid" class="form-control" />
                <span asp-validation-for="Usrid" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Usrname" class="control-label"></label>
                <input asp-for="Usrname" class="form-control" />
                <span asp-validation-for="Usrname" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Usremail" class="control-label"></label>
                <input asp-for="Usremail" class="form-control" />
                <span asp-validation-for="Usremail" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Usrcell" class="control-label"></label>
                <input asp-for="Usrcell" class="form-control" />
                <span asp-validation-for="Usrcell" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Usrsts" class="control-label d-block"></label>
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" role="switch" id="usrStsSwitch"
                           @(Model.Usrsts == 1 ? "checked" : "")
                           onchange="document.getElementById('Usrsts').value = this.checked ? '1' : '0'" />
                    <label class="form-check-label" for="usrStsSwitch">Active</label>
                </div>
                <input type="hidden" asp-for="Usrsts" />
            </div>
            <div class="form-group">
                <label asp-for="Usrrole" class="control-label"></label>
                <select asp-for="Usrrole" asp-items="ViewBag.Usrrole" class="form-select">
                    <option value="">-- Select Role --</option>
                </select>
                <span asp-validation-for="Usrrole" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Usrpar" class="control-label"></label>
                <input asp-for="Usrpar" class="form-control" />
                <span asp-validation-for="Usrpar" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Usriniop" class="control-label"></label>
                <input asp-for="Usriniop" class="form-control" />
                <span asp-validation-for="Usriniop" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
