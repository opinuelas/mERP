@model mERP.Data.User

@{
    ViewData["Title"] = "Reset Password";
}

<h1>Reset Password</h1>

<div>
    <h4>User</h4>
    <hr />
    <div class="row">
      <div class="col-md-4">
        <form asp-action="RstPwd">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">@TempData["SuccessMessage"]</div>
            }
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <label asp-for="Usrid" class="control-label"></label>
                <input asp-for="Usrid" class="form-control" disabled readonly />
            </div>
            <div class="form-group">
                <label asp-for="Usrname" class="control-label"></label>
                <input asp-for="Usrname" class="form-control" disabled readonly />
            </div>
            <div class="form-group">
                <label asp-for="Usrpwd" class="control-label"></label>
                <input asp-for="Usrpwd" type="password" class="form-control" />
                <span asp-validation-for="Usrpwd" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <input type="submit" value="Reset" class="btn btn-primary" />
            </div>
        </form>
      </div>
   </div>
</div>
<div>
    <a asp-action="Details" asp-route-id="@Model?.Id">Back to Details</a> |
    <a asp-action="Index">Back to List</a>
</div>
